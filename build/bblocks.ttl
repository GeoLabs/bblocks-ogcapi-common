<https://geolabs.github.io/bblocks-ogcapi-common/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - OGC API Common" ;
    dct:abstract """Schemas for the OGC API - Common - Part 1: Core standard
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """Adds a flexible, JSON schema version agnostic documentation to the OGC API - Common - Part 1: Core standard, 
supporting further profiling by combining with other Building Blocks.

This includes:
- Landing Page (/)
- Conformance Declaration (/conformance)
- API Definition (/api)
- Common response formats (JSON, HTML)
- Common schemas (links, exceptions, etc.)
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-06-11T16:35:57.951701"^^xsd:dateTime ;
    owl:imports <https://opengeospatial.github.io/bblocks/register.json> ;
    skos:hasTopConcept <bblocks://ogc.api.common.v1.api>,
        <bblocks://ogc.api.common.v1.parameters.f-openapi>,
        <bblocks://ogc.api.common.v1.paths.ApiDefinition>,
        <bblocks://ogc.api.common.v1.paths.Conformance>,
        <bblocks://ogc.api.common.v1.paths.LandingPage>,
        <bblocks://ogc.api.common.v1.responses.ApiDefinition>,
        <bblocks://ogc.api.common.v1.responses.ConformanceDeclaration>,
        <bblocks://ogc.api.common.v1.responses.InvalidParameter>,
        <bblocks://ogc.api.common.v1.responses.LandingPage>,
        <bblocks://ogc.api.common.v1.responses.ServerError>,
        <bblocks://ogc.api.common.v1.schemas.confClasses>,
        <bblocks://ogc.api.common.v1.schemas.exception>,
        <bblocks://ogc.api.common.v1.schemas.landingPage>,
        <bblocks://ogc.api.common.v1.schemas.link> ;
    skos:prefLabel "Building Blocks - OGC API Common" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://geolabs.github.io/bblocks-ogcapi-common/build/bblocks.jsonld> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://geolabs.github.io/bblocks-ogcapi-common/build/register.json> ],
        [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://geolabs.github.io/bblocks-ogcapi-common/build/bblocks.ttl> ] ;
    foaf:homepage <https://geolabs.github.io/bblocks-ogcapi-common/> ;
    bblocks:hasValidationReport <https://geolabs.github.io/bblocks-ogcapi-common/build/tests/report.html> .

